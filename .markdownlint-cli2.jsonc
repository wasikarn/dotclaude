{
  // markdownlint-cli2 options (separate from rule config in .markdownlint.json)
  "ignores": [
    "prompts/**/*.md",
    "*-workspace/**/*.md",
    "docs/superpowers/**/*.md",
    "docs/specs/**/*.md",
    "docs/eval/*.local.md",
    "devflow-engine/node_modules/**/*.md",
    "node_modules/**/*.md"
  ]
}
