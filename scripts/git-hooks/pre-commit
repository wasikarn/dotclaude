#!/bin/sh
# pre-commit: auto-fix markdown tables and lint + QA gates (mirrors GitHub Actions)
# Install: bash scripts/install-hooks.sh

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── 1. markdown auto-fix (staged .md files only) ──────────────────────────────
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -n "$STAGED_MD" ]; then
  FILES_WITH_UNSTAGED=$(git diff --name-only || true)

  echo "Running fix-tables.sh on staged .md files..."
  echo "$STAGED_MD" | xargs bash "$REPO_ROOT/scripts/fix-tables.sh"

  echo "Running markdownlint-cli2 --fix on staged .md files..."
  echo "$STAGED_MD" | xargs npx markdownlint-cli2 --fix

  for FILE in $STAGED_MD; do
    if echo "$FILES_WITH_UNSTAGED" | grep -qx "$FILE"; then
      git diff -- "$FILE" | git apply --cached --whitespace=nowarn 2>/dev/null || git add "$FILE"
    else
      git add "$FILE"
    fi
  done

  echo "Markdown auto-fix complete"
  echo ""
fi

# ── 2. QA gates (mirrors GitHub Actions) ─────────────────────────────────────
bash "$REPO_ROOT/scripts/qa-check.sh"
