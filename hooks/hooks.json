{
  "description": "Workflow automation hooks for devflow — skill routing, quality gates, context injection, and file protection",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/skill-routing.sh",
            "timeout": 10,
            "statusMessage": "Analyzing prompt..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-deps.sh",
            "timeout": 10,
            "statusMessage": "Checking dependencies..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-artifacts.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-compact-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/skill-usage-tracker.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/safe-command-approver.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "timeout": 30,
            "command": "command -v jq > /dev/null 2>&1 && FILE=$(jq -r '.tool_input.file_path // empty') && [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.md$' && npx markdownlint-cli2 --fix \"$FILE\" 2>/dev/null; exit 0"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/shellcheck-written-scripts.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bash-failure-hint.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|max_output_tokens|billing_error|server_error",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-failure-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "review-debate",
        "hooks": [
          {
            "type": "command",
            "command": "GATE_PATTERN='review|debate|finding' GATE_MSG='Your findings must include file:line evidence for every issue. Please re-review and cite specific code locations.' ${CLAUDE_PLUGIN_ROOT}/hooks/task-gate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "devflow",
        "hooks": [
          {
            "type": "command",
            "command": "GATE_PATTERN='devflow|explore|implement|review|fix|finding' GATE_MSG='Your output must include file:line evidence. Re-examine the code and cite specific locations.' ${CLAUDE_PLUGIN_ROOT}/hooks/task-gate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "respond",
        "hooks": [
          {
            "type": "command",
            "command": "GATE_PATTERN='respond|fix-thread|reply-thread' GATE_MSG='Your output must include file:line evidence. Cite the specific file and line number you fixed.' ${CLAUDE_PLUGIN_ROOT}/hooks/task-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "code-reviewer|test-quality-reviewer|migration-reviewer|api-contract-auditor|comment-analyzer|code-simplifier|silent-failure-hunter|type-design-analyzer",
        "hooks": [
          {
            "type": "command",
            "command": "GATE_PATTERN='code-reviewer|test-quality-reviewer|migration-reviewer|api-contract-auditor|comment-analyzer|code-simplifier|silent-failure-hunter|type-design-analyzer' GATE_MSG='Your review output must include file:line evidence for every issue. Re-examine the code and cite specific code locations before finishing.' ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "code-reviewer|test-quality-reviewer|migration-reviewer|api-contract-auditor|falsification-agent|plan-challenger|comment-analyzer|code-simplifier|silent-failure-hunter|type-design-analyzer",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end-cleanup.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "review-pr",
        "hooks": [
          {
            "type": "command",
            "command": "NUDGE_PATTERN='review-pr' NUDGE_CHECK_TASKS=1 NUDGE_MSG=\"You still have pending debate tasks. Please review your assigned teammate's findings and respond with Agree, Challenge, or Escalate per the debate protocol.\" ${CLAUDE_PLUGIN_ROOT}/hooks/idle-nudge.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "devflow",
        "hooks": [
          {
            "type": "command",
            "command": "NUDGE_PATTERN='devflow' NUDGE_CHECK_TASKS=1 NUDGE_MSG='You have pending tasks. Please continue working on your assigned phase tasks and message the team lead when done.' ${CLAUDE_PLUGIN_ROOT}/hooks/idle-nudge.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "respond",
        "hooks": [
          {
            "type": "command",
            "command": "NUDGE_PATTERN='respond' NUDGE_MSG='You are idle. Continue fixing your assigned threads and message the team lead when done. If blocked, message lead with: thread number, what you tried, and where you are stuck.' ${CLAUDE_PLUGIN_ROOT}/hooks/idle-nudge.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "debug-",
        "hooks": [
          {
            "type": "command",
            "command": "NUDGE_PATTERN='^debug-' NUDGE_MSG='You are idle. Continue your investigation and send findings to the team lead when done. If blocked, message the lead with: what you tried, what you found, and where you are stuck.' ${CLAUDE_PLUGIN_ROOT}/hooks/idle-nudge.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
